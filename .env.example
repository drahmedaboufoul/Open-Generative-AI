# =============================================================================
# Xaen marketing-tower deployment of Open Generative AI
# Set these in Vercel → Project → Settings → Environment Variables (do NOT commit real values).
# =============================================================================

# MuAPI key — powers every studio (image / video / cinema / lip-sync / audio / agents).
# When set, the /api proxy injects it server-side; it is NEVER shipped to the browser,
# and users never see the key-entry modal. This is the single source of truth for auth.
MUAPI_API_KEY=

# Managed-mode flag (client-visible). Pair with MUAPI_API_KEY above: it seeds a placeholder
# key in the studio so the key modal is skipped. Set to 1 for the tower deployment; leave
# unset for a public BYO-key build where each user pastes their own key.
NEXT_PUBLIC_MUAPI_MANAGED=1

# Featherless — powers the "Brief → Prompt" helper (the content brain that writes on-brand
# render prompts). Same key the xaen-core marketing tower uses. Server-side only.
FEATHERLESS_API_KEY=

# Optional overrides (defaults shown):
# FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
# FEATHERLESS_URL=https://api.featherless.ai/v1/chat/completions
# MUAPI_BASE_URL=https://api.muapi.ai
